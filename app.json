{
  "expo": {
    "owner": "saurabh_06_09_1",
    "name": "Edumug Admin",
    "slug": "sp_edumug",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_ed.png",
    "scheme": "edumugadmin",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon_ed.png",
      "resizeMode": "contain",
      "backgroundColor": "#6722d5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.edumug.admin",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_ed.png",
        "backgroundColor": "#6722d5"
      },
      "package": "admin.edumug.com"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon_ed.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2bb63d21-48b4-4eca-a194-aa567cccb3b6"
      }
    }
  }
}
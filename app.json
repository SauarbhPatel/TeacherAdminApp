{
  "expo": {
    "name": "TeachDesk",
    "slug": "teachdesk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "teachdesk",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#6722d5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.teachdesk.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#6722d5"
      },
      "package": "com.teachdesk.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5c0ad97-8662-46af-84b2-bc5ba973f603"
      }
    }
  }
}
